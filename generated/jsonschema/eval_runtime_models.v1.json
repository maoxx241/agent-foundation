{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "bundle": "eval_runtime_models.v1",
  "models": {
    "EvalThresholds": {
      "$defs": {
        "MetricThreshold": {
          "additionalProperties": false,
          "properties": {
            "metric": {
              "title": "Metric",
              "type": "string"
            },
            "op": {
              "default": ">=",
              "enum": [
                ">=",
                "<=",
                "=="
              ],
              "title": "Op",
              "type": "string"
            },
            "value": {
              "title": "Value",
              "type": "number"
            }
          },
          "required": [
            "metric",
            "value"
          ],
          "title": "MetricThreshold",
          "type": "object"
        }
      },
      "additionalProperties": false,
      "properties": {
        "max_new_critical_failures": {
          "default": 0,
          "title": "Max New Critical Failures",
          "type": "integer"
        },
        "max_regressed_case_count": {
          "default": 0,
          "title": "Max Regressed Case Count",
          "type": "integer"
        },
        "min_gold_cases": {
          "default": 0,
          "title": "Min Gold Cases",
          "type": "integer"
        },
        "min_replay_cases": {
          "default": 0,
          "title": "Min Replay Cases",
          "type": "integer"
        },
        "profile": {
          "default": "smoke",
          "title": "Profile",
          "type": "string"
        },
        "require_baseline": {
          "default": false,
          "title": "Require Baseline",
          "type": "boolean"
        },
        "retrieval": {
          "items": {
            "$ref": "#/$defs/MetricThreshold"
          },
          "title": "Retrieval",
          "type": "array"
        },
        "workflow": {
          "items": {
            "$ref": "#/$defs/MetricThreshold"
          },
          "title": "Workflow",
          "type": "array"
        }
      },
      "title": "EvalThresholds",
      "type": "object"
    },
    "MetricThreshold": {
      "additionalProperties": false,
      "properties": {
        "metric": {
          "title": "Metric",
          "type": "string"
        },
        "op": {
          "default": ">=",
          "enum": [
            ">=",
            "<=",
            "=="
          ],
          "title": "Op",
          "type": "string"
        },
        "value": {
          "title": "Value",
          "type": "number"
        }
      },
      "required": [
        "metric",
        "value"
      ],
      "title": "MetricThreshold",
      "type": "object"
    },
    "ReleaseCheckReport": {
      "$defs": {
        "ThresholdFailure": {
          "additionalProperties": false,
          "properties": {
            "actual": {
              "default": 0.0,
              "title": "Actual",
              "type": "number"
            },
            "check": {
              "title": "Check",
              "type": "string"
            },
            "expected": {
              "title": "Expected",
              "type": "number"
            },
            "message": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "title": "Message"
            },
            "metric": {
              "title": "Metric",
              "type": "string"
            },
            "op": {
              "title": "Op",
              "type": "string"
            }
          },
          "required": [
            "check",
            "metric",
            "op",
            "expected"
          ],
          "title": "ThresholdFailure",
          "type": "object"
        }
      },
      "additionalProperties": false,
      "properties": {
        "comparison_report_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Comparison Report Path"
        },
        "contract_drift": {
          "default": false,
          "title": "Contract Drift",
          "type": "boolean"
        },
        "ended_at": {
          "title": "Ended At",
          "type": "string"
        },
        "eval_ok": {
          "default": true,
          "title": "Eval Ok",
          "type": "boolean"
        },
        "eval_report_dir": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Eval Report Dir"
        },
        "new_critical_failures": {
          "items": {
            "type": "string"
          },
          "title": "New Critical Failures",
          "type": "array"
        },
        "overall_status": {
          "default": "ok",
          "enum": [
            "ok",
            "failed",
            "blocked"
          ],
          "title": "Overall Status",
          "type": "string"
        },
        "profile": {
          "default": "smoke",
          "title": "Profile",
          "type": "string"
        },
        "regressed_case_ids": {
          "items": {
            "type": "string"
          },
          "title": "Regressed Case Ids",
          "type": "array"
        },
        "replay_ok": {
          "default": true,
          "title": "Replay Ok",
          "type": "boolean"
        },
        "replay_report_dir": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Replay Report Dir"
        },
        "run_id": {
          "title": "Run Id",
          "type": "string"
        },
        "started_at": {
          "title": "Started At",
          "type": "string"
        },
        "threshold_failures": {
          "items": {
            "$ref": "#/$defs/ThresholdFailure"
          },
          "title": "Threshold Failures",
          "type": "array"
        }
      },
      "required": [
        "run_id",
        "started_at",
        "ended_at"
      ],
      "title": "ReleaseCheckReport",
      "type": "object"
    },
    "ReplayRunReport": {
      "$defs": {
        "ReplayCaseResult": {
          "additionalProperties": false,
          "properties": {
            "case_id": {
              "title": "Case Id",
              "type": "string"
            },
            "final_states": {
              "additionalProperties": {
                "type": "string"
              },
              "title": "Final States",
              "type": "object"
            },
            "kind": {
              "title": "Kind",
              "type": "string"
            },
            "ok": {
              "title": "Ok",
              "type": "boolean"
            },
            "steps": {
              "items": {
                "$ref": "#/$defs/ReplayStepResult"
              },
              "title": "Steps",
              "type": "array"
            },
            "task_ids": {
              "items": {
                "type": "string"
              },
              "title": "Task Ids",
              "type": "array"
            },
            "warnings": {
              "items": {
                "type": "string"
              },
              "title": "Warnings",
              "type": "array"
            }
          },
          "required": [
            "case_id",
            "kind",
            "ok"
          ],
          "title": "ReplayCaseResult",
          "type": "object"
        },
        "ReplayStepResult": {
          "additionalProperties": false,
          "properties": {
            "body_excerpt": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "title": "Body Excerpt"
            },
            "method": {
              "title": "Method",
              "type": "string"
            },
            "ok": {
              "title": "Ok",
              "type": "boolean"
            },
            "path": {
              "title": "Path",
              "type": "string"
            },
            "promoted_object_count": {
              "default": 0,
              "title": "Promoted Object Count",
              "type": "integer"
            },
            "state": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "title": "State"
            },
            "status_code": {
              "title": "Status Code",
              "type": "integer"
            },
            "target_state": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "title": "Target State"
            }
          },
          "required": [
            "method",
            "path",
            "status_code",
            "ok"
          ],
          "title": "ReplayStepResult",
          "type": "object"
        },
        "WorkflowMetrics": {
          "additionalProperties": false,
          "properties": {
            "cases_total": {
              "default": 0,
              "title": "Cases Total",
              "type": "integer"
            },
            "design_acceptance_rate": {
              "default": 0.0,
              "title": "Design Acceptance Rate",
              "type": "number"
            },
            "human_intervention_rate": {
              "default": 0.0,
              "title": "Human Intervention Rate",
              "type": "number"
            },
            "regression_escape_rate": {
              "default": 0.0,
              "title": "Regression Escape Rate",
              "type": "number"
            },
            "review_rejection_rate": {
              "default": 0.0,
              "title": "Review Rejection Rate",
              "type": "number"
            },
            "validation_failure_rate": {
              "default": 0.0,
              "title": "Validation Failure Rate",
              "type": "number"
            },
            "writeback_promotion_rate": {
              "default": 0.0,
              "title": "Writeback Promotion Rate",
              "type": "number"
            }
          },
          "title": "WorkflowMetrics",
          "type": "object"
        }
      },
      "additionalProperties": false,
      "properties": {
        "generated_at": {
          "title": "Generated At",
          "type": "string"
        },
        "ok": {
          "default": true,
          "title": "Ok",
          "type": "boolean"
        },
        "replay_results": {
          "items": {
            "$ref": "#/$defs/ReplayCaseResult"
          },
          "title": "Replay Results",
          "type": "array"
        },
        "report_dir": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Report Dir"
        },
        "run_id": {
          "title": "Run Id",
          "type": "string"
        },
        "workflow_metrics": {
          "$ref": "#/$defs/WorkflowMetrics"
        }
      },
      "required": [
        "run_id",
        "generated_at"
      ],
      "title": "ReplayRunReport",
      "type": "object"
    },
    "ThresholdFailure": {
      "additionalProperties": false,
      "properties": {
        "actual": {
          "default": 0.0,
          "title": "Actual",
          "type": "number"
        },
        "check": {
          "title": "Check",
          "type": "string"
        },
        "expected": {
          "title": "Expected",
          "type": "number"
        },
        "message": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Message"
        },
        "metric": {
          "title": "Metric",
          "type": "string"
        },
        "op": {
          "title": "Op",
          "type": "string"
        }
      },
      "required": [
        "check",
        "metric",
        "op",
        "expected"
      ],
      "title": "ThresholdFailure",
      "type": "object"
    }
  }
}
